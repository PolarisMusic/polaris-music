# Polaris Music Registry - Environment Variables
# Copy this file to .env and update with your values

# ====================
# Chain Profile (shared across all components)
# ====================
# Profiles: 'local' | 'jungle4' | 'mainnet'
# All settings below have profile-aware defaults from shared/config/chainProfiles.js
# Set CHAIN_PROFILE to switch environments; override individual vars as needed.
CHAIN_PROFILE=jungle4

# ====================
# Blockchain Configuration
# ====================
# These are derived automatically from CHAIN_PROFILE above.
# Only uncomment/set to override profile defaults.
# For EOS mainnet: CHAIN_PROFILE=mainnet (or override individually below)
# CHAIN_ID=73e4385a2708e6d7048834fbc1079f2fabb17b3c125b146af438971e90716c4d
# RPC_URL=https://jungle4.greymass.com
# CONTRACT_ACCOUNT=polarismusic
# TOKEN_CONTRACT_ACCOUNT=polaristoken
TOKEN_SYMBOL=MUS
TOKEN_PRECISION=4

# ====================
# Chain Ingestion Source
# ====================
# Options: 'substreams' (primary, cloud-hosted) | 'ship' (fallback, direct node)
CHAIN_SOURCE=substreams

# SHiP Configuration — Only used if CHAIN_SOURCE=ship
# SHIP_URL: WebSocket endpoint for state_history_plugin
#   Local:   ws://localhost:8080
#   Jungle4: wss://jungle4.eosusa.io (or other SHiP provider)
# SHIP_URL=ws://localhost:8080
# SHIP_CA_CERT_PATH=                    # CA cert for wss:// connections
# SHIP_REJECT_UNAUTHORIZED=true         # Verify TLS certs (default: true)
# IRREVERSIBLE_ONLY=false               # Only process irreversible blocks
# USE_LOCAL_ABI=false                   # Prefer local ABI over on-chain
# CONTRACT_ABI_PATH=                    # Explicit path to contract ABI JSON file

# ====================
# Graph Database (Neo4j)
# ====================
# NEO4J_PASSWORD is REQUIRED for docker-compose (uses ${VAR:?required} substitution).
# It is the source of truth for both NEO4J_AUTH (neo4j/<password>) and the GRAPH_PASSWORD
# the API/processor/chain-source services connect with.
NEO4J_PASSWORD=polarisdev
GRAPH_URI=bolt://localhost:7687
GRAPH_USER=neo4j
# GRAPH_PASSWORD is consumed by bare-metal backends (npm run dev). In docker-compose it
# is overridden from NEO4J_PASSWORD above.
GRAPH_PASSWORD=polarisdev

# Schema/migration control (default: schema init on, migrations off)
# GRAPH_INIT_SCHEMA=false      # Skip uniqueness/index init at startup
# GRAPH_RUN_MIGRATIONS=true    # Run pending migrations at startup

# ====================
# Storage Configuration
# ====================

# IPFS: Single or multiple nodes for redundancy
# Default: Single node (minimal mode) - easy deployment
IPFS_URLS=http://localhost:5001

# IPFS Redundancy (optional): Add secondary nodes for best-effort replication
# Comma-separated list. First node is primary (writes), others are secondary (replication).
# For local development: run two IPFS daemons on different ports
# IPFS_URLS=http://localhost:5001,http://localhost:5002
# For Docker Compose with ipfs2: http://ipfs:5001,http://ipfs2:5001

# IPFS_URL (legacy): Single node endpoint (deprecated - use IPFS_URLS instead)
# IPFS_URL=http://localhost:5001

# S3 (MinIO for local dev)
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD are REQUIRED for docker-compose (uses ${VAR:?required}).
# In compose they double as S3_ACCESS_KEY / S3_SECRET_KEY for the api, processor, and
# chain-source services so the credentials don't drift.
MINIO_ROOT_USER=polaris
MINIO_ROOT_PASSWORD=polarisdev123
S3_ENDPOINT=http://localhost:9000
# S3_ACCESS_KEY / S3_SECRET_KEY are consumed by bare-metal backends. In docker-compose
# they are overridden from MINIO_ROOT_USER / MINIO_ROOT_PASSWORD above.
S3_ACCESS_KEY=polaris
S3_SECRET_KEY=polarisdev123
S3_BUCKET=polaris-events
S3_REGION=us-east-1

# IPFS public gateway used to construct ipfs:// URLs in API responses.
# Default: https://ipfs.io/ipfs/
# IPFS_GATEWAY=https://ipfs.io/ipfs/

# Storage encryption (optional; recommended for production)
# 64 hex characters (32-byte / 256-bit key). When set, S3 + Redis event
# payloads are AES-256-GCM encrypted at rest. When unset, payloads are
# stored in plaintext. Generate with: openssl rand -hex 32
# STORAGE_ENCRYPTION_KEY=

# ====================
# Redis Cache
# ====================
# REDIS_PASSWORD is REQUIRED for docker-compose (uses ${VAR:?required}). Used both as
# the redis-server --requirepass and as the API/processor REDIS_PASSWORD.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=polarisdev
# REDIS_TTL: seconds before cached events expire. Default: 86400 (24h).
# REDIS_TTL=86400

# ====================
# API Server Configuration
# ====================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=debug

# Ingestion path (HTTP /api/ingest/anchored-event vs chain-watching).
# INGEST_MODE: 'chain' (default) | 'http' — switches which API key the
#   middleware enforces and how /api/identity/mint persists events.
# INGEST_API_KEY: required when INGEST_MODE=http (middleware checks Bearer token).
# INGEST_MODE=chain
# INGEST_API_KEY=

# Ingestion batching (request → graph). All optional; defaults shown.
# INGESTION_ENABLE_BATCHING=true     # set 'false' to flush every event individually
# INGESTION_BATCH_SIZE=100           # max events per batch
# INGESTION_BATCH_TIMEOUT_MS=1000    # max wait before flushing a partial batch

# ====================
# Event Processor Configuration
# ====================
START_BLOCK=0
BATCH_SIZE=100
POLL_INTERVAL=5000

# RPC TLS hardening (optional; useful for self-signed or strict-cipher hosts)
# RPC_CA_CERT_PATH: path to a PEM CA bundle to add to the trust store.
# RPC_REJECT_UNAUTHORIZED: 'false' disables TLS verification (NEVER in prod).
# RPC_CIPHERS: OpenSSL cipher list, e.g. 'TLS_AES_256_GCM_SHA384:HIGH'.
# RPC_CA_CERT_PATH=
# RPC_REJECT_UNAUTHORIZED=true
# RPC_CIPHERS=

# ====================
# Frontend Configuration
# ====================
VITE_API_URL=http://localhost:3000
VITE_GRAPHQL_URL=http://localhost:3000/graphql

# ====================
# Smoke Test Configuration (Development/Testing Only)
# ====================
# These variables enable the smoke test script (./scripts/smoke_pipeline.sh)
# to validate the full pipeline without requiring blockchain access.
#
# WARNING: These are for development/testing ONLY. Never use in production!

# DEV_SIGNER_PRIVATE_KEY: EOSIO private key for server-side signing
#   - Enables POST /api/events/dev-sign and GET /api/events/dev-pubkey endpoints
#   - Only enabled when NODE_ENV !== 'production' (production safety enforced)
#   - Docker Compose sets this by default (well-known EOSIO dev key)
#   - For bare-metal dev, set this to enable smoke tests:
DEV_SIGNER_PRIVATE_KEY=5KQwrPbwdL6PhXujxW37FSSQZ1JiwsST4cqQzDeyXtP79zkvFD3

# REQUIRE_ACCOUNT_AUTH: Disable blockchain account verification for smoke tests
#   - Default: true (secure, verifies key authorized for account)
#   - Set to 'false' for smoke tests (skips RPC account verification)
#   - WARNING: Only set to 'false' for smoke tests
# REQUIRE_ACCOUNT_AUTH=false

# ====================
# Substreams Chain Ingestion (Optional)
# ====================
# Get your API token from https://app.pinax.network
# Uncomment and set to enable automated blockchain event ingestion
# IMPORTANT: Endpoint must match the chain used above (CHAIN_ID/RPC_URL)

# SUBSTREAMS_API_TOKEN=your_pinax_api_token_here
# SUBSTREAMS_API_KEY=your_pinax_api_key_here         # Alternative name (either works)
# SUBSTREAMS_ENDPOINT=jungle4.substreams.pinax.network:443    # Default: Jungle4 testnet
# SUBSTREAMS_ENDPOINT=eos.substreams.pinax.network:443        # For EOS mainnet

# Substreams package configuration
# CRITICAL: Params must use module-keyed format: <module_name>=<value>
# NOTE: Do NOT use quotes in param values - they will be passed literally to the CLI
#
# DEFAULT (Recommended): Local package with embedded contract ABI
#   - Package is built automatically in Docker image build
#   - No dependency on Pinax having our contract ABI
#   - Works reliably on testnets and custom deployments
# SUBSTREAMS_PACKAGE=/app/substreams/polaris_music_substreams-v0.1.0.spkg  # (default)
# SUBSTREAMS_MODULE=map_anchored_events                                      # (default)
# SUBSTREAMS_PARAMS=map_anchored_events=polaris                              # (default)
#
# FALLBACK: Pinax foundational modules (requires Pinax to have your contract ABI)
#   - May fail silently if Pinax cannot decode contract actions
#   - Only use if local package build fails
# SUBSTREAMS_PACKAGE=https://spkg.io/pinax-network/antelope-common-v0.4.0.spkg
# SUBSTREAMS_MODULE=filtered_actions
# SUBSTREAMS_PARAMS=filtered_actions=code:polaris && action:put
